# ═══ Real Estate Investment Analyzer — Environment Variables ═══
# Copy this file to .env and fill in your actual keys:
#   cp .env.example .env

# OpenRouter API Key (required — used by Agent A, Agent B, and embeddings)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-your-key-here"

# Groq API Key (optional — used for Whisper speech-to-text)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY="gsk_your-key-here"

# Qdrant Vector Database (defaults work for docker-compose)
QDRANT_HOST="localhost"
QDRANT_PORT=6333

# Agent System B URL (defaults work for docker-compose)
AGENT_B_URL="http://localhost:8001"

# MCP Server URL (defaults work for docker-compose)
MCP_SERVER_URL="http://localhost:8002"

# Frontend CORS origins (defaults work for docker-compose)
CORS_ORIGINS="http://localhost:5173"

# LangSmith Observability (optional — set to "true" to enable tracing)
# LANGCHAIN_TRACING_V2="true"
# LANGCHAIN_API_KEY="your-langsmith-key"
# LANGCHAIN_PROJECT="real-estate-analyzer"

# Logging level (default: INFO)
# LOG_LEVEL="INFO"
